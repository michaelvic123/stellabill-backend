{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stellabill Log Schema",
  "description": "JSON schema for structured log entries",
  "type": "object",
  "required": ["time", "level", "msg", "request_id", "trace_id", "tenant_id"],
  "properties": {
    "time": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the log entry"
    },
    "level": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error", "fatal", "panic"],
      "description": "Log level"
    },
    "msg": {
      "type": "string",
      "description": "Log message"
    },
    "request_id": {
      "type": "string",
      "description": "Unique request identifier"
    },
    "trace_id": {
      "type": "string",
      "description": "Distributed tracing identifier"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant/organization identifier"
    },
    "correlation_id": {
      "type": "string",
      "description": "Optional correlation identifier for related requests"
    },
    "method": {
      "type": "string",
      "description": "HTTP method (for request logs)"
    },
    "path": {
      "type": "string",
      "description": "HTTP path (for request logs)"
    },
    "status": {
      "type": "integer",
      "description": "HTTP status code (for request logs)"
    },
    "latency_ms": {
      "type": "integer",
      "description": "Request latency in milliseconds"
    },
    "client_ip": {
      "type": "string",
      "description": "Client IP address"
    }
  }
}
